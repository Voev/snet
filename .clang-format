---
AccessModifierOffset: -4
AlignAfterOpenBracket: Align
AllowAllArgumentsOnNextLine: 'true'  # ← меняем на true
AllowShortFunctionsOnASingleLine: 'false'
AllowShortBlocksOnASingleLine: 'false'
AllowShortLambdasOnASingleLine: 'false'  # ← добавляем
AlwaysBreakTemplateDeclarations: Yes
BinPackArguments: false  # ← добавляем
BreakBeforeBraces: Allman
BreakConstructorInitializers: BeforeComma
ColumnLimit: '120'
IndentWidth: '4'
LambdaBodyIndentation: Signature
PenaltyBreakBeforeFirstCallParameter: 1  # ← уже есть
PenaltyExcessCharacter: 100  # ← добавляем
PenaltyReturnTypeOnItsOwnLine: 100  # ← добавляем
PointerAlignment: Left
SortIncludes: 'false'
SortUsingDeclarations: 'false'
SpacesInAngles: 'false'
SpacesInCStyleCastParentheses: 'false'
SpacesInParentheses: 'false'
SpacesInSquareBrackets: 'false'
Standard: Auto
UseTab: Never

BraceWrapping:
  AfterExternBlock: false